{
  "name": "抖音极速版-签到领金币",
  "entry": {
    "start_from_home": true,
    "launch": {
      "package": "com.ss.android.ugc.aweme.lite",
      "wait_seconds": 4
    },
    "steps": [
      {
        "type": "click_text",
        "click_target": "首页",
        "offset": {
          "x": 500,
          "y": 0
        },
        "scope": "bottom"
      },
      {
        "type": "sleep",
        "seconds": 2
      }
    ]
  },
  "execute": {
    "poll_interval_seconds": 3,
    "screenshot_dir": "task_engine_v2/screenshots",
    "required_activities": [
      "com.ss.android.ugc.aweme.lite/com.bytedance.android.anniex.container.AnnieXHostActivity",
      "com.ss.android.ugc.aweme.lite/com.ss.android.ugc.aweme.splash.SplashActivity"
    ],
    "scenarios": [
      {
        "name": "获得开宝箱奖励",
        "have_text": [
          "获得开宝箱奖励",
          "开心收下"
        ],
        "scope": "center",
        "action": {
          "type": "click_text",
          "click_target": "开心收下"
        }
      },
      {
        "name": "去签到",
        "have_text": [
          "去签到"
        ],
        "scope": "center",
        "action": {
          "type": "click_text",
          "click_target": "去签到"
        }
      },
      {
        "name": "连续打卡7天",
        "have_text": [
          "连续打卡",
          "立即打卡"
        ],
        "action": {
          "type": "click_text",
          "click_target": "立即打卡"
        }
      },
      {
        "name": "打卡-签到",
        "action": {
          "type": "click_text",
          "click_target": [
            "立即打卡",
            "立即签到",
            "立即领取"
          ]
        }
      }
    ]
  },
  "exit": {
    "max_duration_seconds": 30,
    "stop_on_action_types": [
      "stop_task"
    ]
  }
}
