{
  "name": "红果免费视频-点击领金币",
  "entry": {
    "start_from_home": true,
    "launch": {
      "package": "com.phoenix.read",
      "wait_seconds": 4
    },
    "steps": [
      {
        "type": "click_text",
        "click_target": [
          "福利",
          "赚钱"
        ],
        "target_match": "or",
        "scope": "bottom",
        "check_wait_seconds": 2,
        "check_if_have": "金币收益",
        "check_scope": "top"
      },
      {
        "type": "sleep",
        "seconds": 2
      }
    ]
  },
  "execute": {
    "poll_interval_seconds": 3,
    "screenshot_dir": "task_engine_v2/screenshots",
    "required_activities": [
      "com.phoenix.read/com.dragon.read.pages.main.MainFragmentActivity",
      "com.phoenix.read/com.ss.android.excitingvideo.ExcitingVideoActivity"
    ],
    "scenarios": [
      {
        "name": "请选择宝箱",
        "have_text": [
          "坚持退出",
          "继续观看"
        ],
        "scope": "center",
        "action": {
          "type": "click_text",
          "click_target": "继续观看"
        }
      },
      {
        "name": "恭喜获得开宝箱奖励",
        "have_text": [
          "恭喜获得开宝箱奖励",
          "看视频最高"
        ],
        "scope": "center",
        "action": {
          "type": "click_text",
          "click_target": "看视频最高"
        }
      },
      {
        "name": "再看一个视频",
        "have_text": [
          "再看一个视频",
          "领取奖励"
        ],
        "scope": "center",
        "action": {
          "type": "click_text",
          "click_target": "领取奖励"
        }
      },
      {
        "name": "请选择宝箱",
        "have_text": [
          "金币",
          "看视频奖励"
        ],
        "scope": "center_right",
        "action": {
          "type": "click_text",
          "click_target": "看视频奖励",
          "offset": {
            "x": 0,
            "y": 120
          }
        }
      },
      {
        "name": "领取成功 X",
        "have_text": [
          "广告",
          "领取成功",
          "×"
        ],
        "scope": "top",
        "action": {
          "type": "click_text",
          "click_target": "×"
        }
      },
      {
        "name": "点击领金币",
        "have_text": [
          "点击领"
        ],
        "action": {
          "type": "click_text",
          "click_target": "点击领"
        }
      }
    ]
  },
  "exit": {
    "max_duration_seconds": 600,
    "stop_on_action_types": [
      "stop_task"
    ]
  }
}