{
  "name": "快手极速版-看广告",
  "entry": {
    "start_from_home": true,
    "launch": {
      "package": "com.kuaishou.nebula",
      "activity": "com.yxcorp.gifshow.HomeActivity",
      "wait_seconds": 4
    },
    "steps": [
      {
        "type": "click_text",
        "target": "赚",
        "scope": "bottom",
        "check_wait_seconds": 2,
        "check": "任务中心",
        "check_scope": "top"
      },
      {
        "type": "sleep",
        "seconds": 2
      },
      {
        "type": "click_text",
        "target": "看广告得金币"
      }
    ]
  },
  "execute": {
    "poll_interval_seconds": 3,
    "screenshot_dir": "task_engine_v2/screenshots",
    "required_activities": [
      "com.kuaishou.nebula/com.yxcorp.gifshow.HomeActivity",
      "com.kuaishou.nebula/com.yxcorp.gifshow.ad.neo.video.award.AwardVideoPlayActivity"
    ],
    "scenarios": [
      {
        "name": "瓜分百亿金币",
        "screen_text": [
          "瓜分",
          "立即参与"
        ],
        "scope": "center",
        "action": {
          "type": "click_text",
          "target": "立即参与"
        }
      },
      {
        "name": "任务中心-看广告",
        "screen_text": [
          "任务中心",
          "看广告得金币",
          "领福利"
        ],
        "action": {
          "type": "click_text",
          "target": "领福利"
        }
      },
      {
        "name": "看完广告",
        "scope": "center",
        "screen_text": [
          "再看1个广告",
          "奖励"
        ],
        "action": {
          "type": "click_text",
          "target": "奖励"
        }
      },
      {
        "name": "看完广告-领取奖励",
        "scope": "center",
        "screen_text": [
          "再看一个再领",
          "领取奖励"
        ],
        "action": {
          "type": "click_text",
          "target": "领取奖励"
        }
      },
      {
        "name": "额外金币",
        "scope": "center",
        "screen_text": [
          "额外",
          "领取额外金币"
        ],
        "action": {
          "type": "click_text",
          "target": "领取额外金币"
        }
      },
      {
        "name": "签到去看视频",
        "scope": "center",
        "screen_text": [
          "签到可领",
          "去看视频"
        ],
        "action": {
          "type": "click_text",
          "target": "去看视频"
        }
      },
      {
        "name": "顶部滑动关闭",
        "scope": "top_left",
        "screen_text": [
          "功领取"
        ],
        "action": {
          "type": "swipe",
          "start_x": 0,
          "start_y": 208,
          "end_x": 308,
          "end_y": 202,
          "duration_ms": 150
        }
      }
    ]
  },
  "exit": {
    "max_duration_seconds": 600,
    "stop_on_action_types": [
      "stop_task"
    ]
  }
}
